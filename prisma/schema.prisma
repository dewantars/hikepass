generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int       @id @default(autoincrement())
  phone      String    @unique @db.VarChar(20)
  name       String?   @db.VarChar(100)
  password   String?   @db.VarChar(255)
  role       Role      @default(USER)
  mountainId Int?
  mountain   Mountain? @relation("AdminMountain", fields: [mountainId], references: [id])
  bookings   Booking[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Mountain {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(100)
  location       String    @db.VarChar(200)
  province       String    @db.VarChar(100)
  altitude       Int
  dailyQuota     Int
  minGroupSize   Int       @default(3)
  maxGroupSize   Int       @default(10)
  pricePerPerson Int
  description    String?   @db.Text
  imageUrl       String?   @db.VarChar(500)
  trails         Trail[]
  bookings       Booking[]
  admins         User[]    @relation("AdminMountain")
  closures       Closure[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([province])
}

model Trail {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(100)
  mountainId Int
  mountain   Mountain  @relation(fields: [mountainId], references: [id], onDelete: Cascade)
  isOpen     Boolean   @default(true)
  bookings   Booking[]

  @@index([mountainId])
}

model Booking {
  id              Int             @id @default(autoincrement())
  bookingCode     String          @unique @db.VarChar(30)
  userId          Int
  user            User            @relation(fields: [userId], references: [id])
  mountainId      Int
  mountain        Mountain        @relation(fields: [mountainId], references: [id])
  trailId         Int
  trail           Trail           @relation(fields: [trailId], references: [id])
  hikingDate      DateTime        @db.Date
  totalMembers    Int
  totalPrice      Int
  status          BookingStatus   @default(PENDING)
  paymentProofUrl String?         @db.VarChar(500)
  qrToken         String          @unique @db.VarChar(100)
  checkInAt       DateTime?
  checkOutAt      DateTime?
  members         BookingMember[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([mountainId])
  @@index([hikingDate])
  @@index([status])
}

enum BookingStatus {
  PENDING
  WAITING_CONFIRM
  PAID
  CHECKED_IN
  COMPLETED
  CANCELLED
  EXPIRED
}

model BookingMember {
  id            Int     @id @default(autoincrement())
  bookingId     Int
  booking       Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  name          String  @db.VarChar(100)
  nik           String  @db.VarChar(16)
  phone         String  @db.VarChar(20)
  isLeader      Boolean @default(false)
  ktpImageUrl   String? @db.VarChar(500)
  healthCertUrl String? @db.VarChar(500)

  @@index([bookingId])
}

model Closure {
  id         Int      @id @default(autoincrement())
  mountainId Int
  mountain   Mountain @relation(fields: [mountainId], references: [id], onDelete: Cascade)
  reason     String   @db.VarChar(200)
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([mountainId])
  @@index([startDate, endDate])
}

model OtpSession {
  id        Int      @id @default(autoincrement())
  phone     String   @db.VarChar(20)
  code      String   @db.VarChar(6)
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, code])
}
